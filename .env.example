# ============================================================
# Skorify Frontend — Variables de entorno
# ============================================================
# Copia este archivo como .env.local para desarrollo local:
#   cp .env.example .env.local
#
# NUNCA subas .env.local ni ningún archivo con valores reales
# al repositorio. Solo .env.example se commitea.
# ============================================================

# ------------------------------------------------------------
# API
# ------------------------------------------------------------
# URL base del backend de Skorify. Incluye el protocolo y,
# si corresponde, el path base (ej. /api/v1).
# Debe ser una URL válida con http:// o https://.
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1

# ------------------------------------------------------------
# App
# ------------------------------------------------------------
# URL pública del frontend. Se usa para generar links de invitación.
NEXT_PUBLIC_APP_URL=http://localhost:3000
